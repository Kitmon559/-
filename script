-- Функции для Item ESP
local function addHighlightToItem(item)
    if not item:IsA("BasePart") then return end
    if itemHighlightCache[item] then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "DropHighlight"
    highlight.FillColor = Color3.fromRGB(255, 0, 0)
    highlight.OutlineColor = Color3.fromRGB(200, 0, 0)
    highlight.FillTransparency = 0.3
    highlight.OutlineTransparency = 0
    highlight.Adornee = item
    highlight.Parent = item
    
    itemHighlightCache[item] = highlight
    highlight.Enabled = true
end

local function removeHighlightFromItem(item)
    local highlight = itemHighlightCache[item]
    if highlight then
        highlight:Destroy()
        itemHighlightCache[item] = nil
    end
end

local function processAllItems(folder)
    for _, child in ipairs(folder:GetChildren()) do
        if child:IsA("BasePart") then
            addHighlightToItem(child)
        elseif child:IsA("Model") or child:IsA("Folder") then
            for _, descendant in ipairs(child:GetDescendants()) do
                if descendant:IsA("BasePart") then
                    addHighlightToItem(descendant)
                end
            end
        end
    end
end

local function clearAllItemHighlights()
    for item, highlight in pairs(itemHighlightCache) do
        if highlight and highlight.Parent then
            highlight:Destroy()
        end
    end
    table.clear(itemHighlightCache)
end

local function stopItemESP()
    itemEspActive = false
