end

local function startItemESP()
    if not scriptLoaded then return end
    
    if itemEspCoroutine then
        coroutine.close(itemEspCoroutine)
    end
    
    itemEspCoroutine = coroutine.create(function()
        local connections = {}
        
        local function cleanup()
            for _, conn in pairs(connections) do
                if conn then pcall(function() conn:Disconnect() end) end
            end
            connections = {}
        end
        
        local function setupDropsTracking(dropsFolder)
            if not scriptLoaded or not itemEspActive then 
                cleanup()
                return 
            end
            
            pcall(function() processAllItems(dropsFolder) end)
            
            local childAddedConn = dropsFolder.ChildAdded:Connect(function(child)
                if not scriptLoaded or not itemEspActive then return end
                task.wait()
                pcall(function()
                    if child:IsA("BasePart") then
                        addHighlightToItem(child)
                    elseif child:IsA("Model") or child:IsA("Folder") then
                        for _, descendant in ipairs(child:GetDescendants()) do
                            if descendant:IsA("BasePart") then
                                addHighlightToItem(descendant)
                            end
                        end
                    end
                end)
            end)
            table.insert(connections, childAddedConn)
            
            local childRemovedConn = dropsFolder.ChildRemoved:Connect(function(child)
                if not scriptLoaded or not itemEspActive then return end
                pcall(function()
                    if child:IsA("BasePart") then
                        removeHighlightFromItem(child)
                    elseif child:IsA("Model") or child:IsA("Folder") then
                        for _, descendant in ipairs(child:GetDescendants()) do
                            if descendant:IsA("BasePart") then
                                removeHighlightFromItem(descendant)
                            end
                        end
                    end
                end)
            end)
            table.insert(connections, childRemovedConn)
        end
        
        local function waitForDrops()
            if not scriptLoaded or not itemEspActive then return end
            local dropsFolder = workspace:FindFirstChild("Drops")
            
            if dropsFolder then
                setupDropsTracking(dropsFolder)
            else
                local connection
                connection = workspace.ChildAdded:Connect(function(child)
                    if child.Name == "Drops" and child:IsA("Folder") and scriptLoaded and itemEspActive then
                        connection:Disconnect()
                        setupDropsTracking(child)
                    end
                end)
                table.insert(connections, connection)
            end
        end
        
        while scriptLoaded and itemEspActive do
            cleanup()
            waitForDrops()
            task.wait(2)
        end
        
        cleanup()
    end)
    coroutine.resume(itemEspCoroutine)
end

-- Функция полной выгрузки скрипта
local function unloadScript()
    if not scriptLoaded then return end
    
    scriptLoaded = false
    
    if doorEspCoroutine then
        pcall(function() coroutine.close(doorEspCoroutine) end)
        doorEspCoroutine = nil
    end
    pcall(function() removeAllDoorHighlights() end)
    
    if itemEspCoroutine then
        pcall(function() coroutine.close(itemEspCoroutine) end)
        itemEspCoroutine = nil
    end
    pcall(function() clearAllItemHighlights() end)
    
    stopGoldESP()
    stopHideESP()
    stopEntityNotifications()
    
    if antiA90Coroutine then
        pcall(function() coroutine.close(antiA90Coroutine) end)
        antiA90Coroutine = nil
    end
    
    if screenGui then
        pcall(function() screenGui:Destroy() end)
        screenGui = nil
    end
    
    isMenuOpen = false
    doorEspActive = false
    itemEspActive = false
    goldEspActive = false
    hideEspActive = false
    antiA90Active = false
    
    print("✅ Скрипт полностью выгружен!")
end

