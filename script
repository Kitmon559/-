local function isPlayer(instance)
    if instance:IsA("Model") then
        return Players:GetPlayerFromCharacter(instance) ~= nil
    end
    return false
end

local function cleanDetected()
    for obj, _ in pairs(detectedEntities) do
        if not obj or not obj.Parent then
            detectedEntities[obj] = nil
        end
    end
end

local function setupEntityNotifications()
    if not entityNotificationsActive or not scriptLoaded then return end
    
    for _, conn in pairs(notificationConnections) do
        pcall(function() conn:Disconnect() end)
    end
    table.clear(notificationConnections)
    table.clear(detectedEntities)
    
    local childAddedConn = workspace.ChildAdded:Connect(function(child)
        task.wait(0.05)
        cleanDetected()
        
        if not isPlayer(child) and entityNotificationsActive then
            local childName = child.Name
            local isTarget, matchedName = isTargetEntity(childName)
            
            if isTarget and not detectedEntities[child] then
                detectedEntities[child] = true
                showNotification(matchedName, childName)
            end
        end
    end)
    table.insert(notificationConnections, childAddedConn)
    
    task.wait(1)
    for _, obj in pairs(workspace:GetChildren()) do
        if not isPlayer(obj) and entityNotificationsActive then
            local objName = obj.Name
            local isTarget, matchedName = isTargetEntity(objName)
            
            if isTarget and not detectedEntities[obj] then
                detectedEntities[obj] = true
                showNotification(matchedName, objName)
            end
        end
    end
    
    local descendantAddedConn = workspace.DescendantAdded:Connect(function(descendant)
        task.wait(0.05)
        if not isPlayer(descendant) and entityNotificationsActive then
            local descName = descendant.Name
            local isTarget, matchedName = isTargetEntity(descName)
            
            if isTarget and not detectedEntities[descendant] then
                detectedEntities[descendant] = true
                showNotification(matchedName, descName)
            end
        end
    end)
    table.insert(notificationConnections, descendantAddedConn)
    
    print("═══════════════════════════════════════════")
    print("✨ КРАСИВАЯ СИСТЕМА ОБНАРУЖЕНИЯ ЗАПУЩЕНА ✨")
    print("═══════════════════════════════════════════")
end

