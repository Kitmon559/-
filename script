local function scanAndHighlightRoomsLockers()
    if not hideEspActive or not scriptLoaded then return 0 end
    
    local foundCount = 0
    local descendants = workspace:GetDescendants()
    
    for _, obj in ipairs(descendants) do
        if obj.Name == "Rooms_Locker" then
            local needsHighlight = false
            
            if obj:IsA("BasePart") then
                if not hideHighlightCache[obj] then
                    needsHighlight = true
                end
            elseif obj:IsA("Model") then
                for _, part in ipairs(obj:GetDescendants()) do
                    if part:IsA("BasePart") and not hideHighlightCache[part] then
                        needsHighlight = true
                        break
                    end
                end
            end
            
            if needsHighlight then
                highlightRoomsLocker(obj)
                foundCount = foundCount + 1
            end
        end
    end
    
    cleanupHideHighlights()
    return foundCount
end

local function setupHideTracking()
    if not hideEspActive or not scriptLoaded then return end
    
    local function trackContainer(container)
        if not hideEspActive or not scriptLoaded then return end
        
        local childAddedConn
        childAddedConn = container.ChildAdded:Connect(function(child)
            if not hideEspActive or not scriptLoaded then
                if childAddedConn then childAddedConn:Disconnect() end
                return
            end
            
            if child.Name == "Rooms_Locker" then
                task.wait(0.05)
                highlightRoomsLocker(child)
            end
            
            if child:IsA("Folder") or child:IsA("Model") then
                task.wait(0.05)
                for _, subChild in ipairs(child:GetDescendants()) do
                    if subChild.Name == "Rooms_Locker" then
                        highlightRoomsLocker(subChild)
                    end
                end
                trackContainer(child)
            end
        end)
    end
    
    trackContainer(workspace)
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Folder") or obj:IsA("Model") then
            trackContainer(obj)
        end
    end
end

