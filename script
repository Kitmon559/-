    "Jeff The Killer", "Sally", "Monument"
}

local ignoreWords = { "fake", "damage" }
local detectedEntities = {}
local notificationConnections = {}

local function shouldIgnore(name)
    local lowerName = string.lower(name)
    for _, ignoreWord in pairs(ignoreWords) do
        if string.find(lowerName, ignoreWord) then
            return true
        end
    end
    return false
end

local function isTargetEntity(name)
    if shouldIgnore(name) then
        return false, nil
    end
    
    for _, entityName in pairs(entitiesList) do
        if name == entityName then
            return true, entityName
        end
        if string.find(name, entityName) then
            return true, entityName
        end
    end
    return false, nil
end

local function speakText(text)
    pcall(function()
