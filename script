    if gameProcessed then return end
    if not scriptLoaded then return end
    
    if input.KeyCode == Enum.KeyCode.K then
        if isMenuOpen then
            if screenGui then
                if mainFrame then
                    savedPosition = mainFrame.Position
                end
                pcall(function() screenGui:Destroy() end)
                screenGui = nil
                isMenuOpen = false
            end
        else
            createMenu()
            isMenuOpen = true
        end
    end
end)

